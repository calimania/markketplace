{
  "kind": "collectionType",
  "collectionName": "rsvps",
  "info": {
    "singularName": "rsvp",
    "pluralName": "rsvps",
    "displayName": "RSVP",
    "description": "Content type event registrations"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "email": {
      "type": "email",
      "required": true
    },
    "name": {
      "type": "string"
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "rsvps"
    },
    "usd_price": {
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "default": 0,
      "type": "decimal"
    },
    "approved": {
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "type": "boolean"
    },
    "sendgrid_contact_id": {
      "type": "string"
    },
    "sendgrid_list_id": {
      "type": "string"
    },
    "last_synced_at": {
      "type": "datetime"
    },
    "sync_status": {
      "type": "enumeration",
      "enum": [
        "pending",
        "synced",
        "failed"
      ],
      "default": "pending"
    },
    "event": {
      "type": "relation",
      "relation": "manyToOne",
      "required": true,
      "target": "api::event.event"
    },
    "store": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::store.store"
    }
  }
}